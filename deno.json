{
  "name": "@worlds/denokv",
  "version": "0.0.1",
  "license": "WTFPL",
  "nodeModulesDir": "auto",
  "exclude": [
    "vendor/jsonld-context-parser/**"
  ],
  "exports": {
    ".": "./src/mod.ts",
    "./quad-store": "./src/denokv/quad-store/mod.ts",
    "./search-index": "./src/denokv/search-index/mod.ts",
    "./rdfjs-store": "./src/denokv/rdfjs-store/mod.ts"
  },
  "imports": {
    "@/": "./src/",
    "@rdfjs/types": "npm:@rdfjs/types@^2.0.1",
    "n3": "npm:n3@^2.0.3",
    "@worlds/client": "jsr:@worlds/client@0.0.17",
    "@worlds/client/quad-store": "jsr:@worlds/client@0.0.17/quad-store",
    "@worlds/client/search-index": "jsr:@worlds/client@0.0.17/search-index",
    "@worlds/client/adapters/comunica": "jsr:@worlds/client@0.0.17/adapters/comunica",
    "@worlds/client/denokv": "jsr:@worlds/client@0.0.17/adapters/denokv",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/async": "jsr:@std/async@^1.4.0",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/path": "jsr:@std/path@^1.1.5",
    "@comunica/query-sparql-rdfjs-lite": "npm:@comunica/query-sparql-rdfjs-lite@^5.2.3"
  },
  "publish": {
    "exclude": [
      "**/*.test.ts",
      "**/*-for-test.ts",
      "benchmarks/",
      ".github/",
      "AGENTS.md",
      "deno.lock"
    ]
  },
  "tasks": {
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "check": "deno check",
    "test": "deno test --allow-all --unstable-kv",
    "publish:dry": "deno publish --dry-run --allow-dirty",
    "ci": {
      "description": "Formats, lints, checks, and tests the code",
      "dependencies": [
        "fmt:check",
        "lint",
        "check",
        "test"
      ]
    },
    "example:denokv-hello-world": "deno run -A --unstable-kv examples/denokv-hello-world/main.ts",
    "bench": "deno bench --allow-all --unstable-kv benchmarks/",
    "bench:denokv-pressure": "deno bench --allow-all --unstable-kv benchmarks/denokv-pressure.bench.ts",
    "bench:sparql-perf-denokv": "deno bench --allow-all --unstable-kv benchmarks/sparql-perf-denokv.bench.ts",
    "bench:sparql-perf-denokv:full-scan": "deno bench --allow-all --unstable-kv --env BENCH_HEXASTORE_PERF_FULL_SCAN=1 benchmarks/sparql-perf-denokv.bench.ts",
    "bench:sparql-perf-large-denokv": "deno bench --allow-all --unstable-kv --v8-flags=--max-old-space-size=8192 benchmarks/sparql-perf-large-denokv.bench.ts",
    "bench:sparql-perf-large-denokv:full-scan": "deno bench --allow-all --unstable-kv --env BENCH_HEXASTORE_PERF_FULL_SCAN=1 --v8-flags=--max-old-space-size=8192 benchmarks/sparql-perf-large-denokv.bench.ts",
    "bench:sparql-perf-large-denokv:reuse": "deno bench --allow-all --unstable-kv --env BENCH_REUSE_DB=1 --v8-flags=--max-old-space-size=8192 benchmarks/sparql-perf-large-denokv.bench.ts"
  }
}
